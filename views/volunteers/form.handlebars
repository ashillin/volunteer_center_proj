<form action="/volunteers/upsert" role="form" method="post">
<input type="hidden" name="_csrf" value="{{_csrfToken}}">
  <div><h1>Add a new Volunteer</h1></div>
{{#if volunteer}}
    <div>
      <h2>{{volunteer.firstName}} {{volunteer.lastName}}</h2>
      <input type="hidden" name="id" value="{{volunteer.id}}">
    </div>
{{/if}}
  <div>
    <label for="first_name">First Name</label>
    <input type="text" id="first_name" name="firstName" {{#if volunteer}}value="{{volunteer.firstName}}"{{/if}}>
  </div>
  <div>
    <label for="last_name">Last Name</label>
    <input type="text" id="last_name" name="lastName" {{#if volunteer}}value="{{volunteer.lastName}}"{{/if}}>
  </div>
  <button type="submit" class="btn btn-primary">Submit</button>
</form>