<!DOCTYPE html>
<html lang="en">
  <head>
    <title>{{title}}</title>
  </head>
  <body>
    {{#if flash}}
      <div>
        <strong>{{flash.intro}}</strong> {{{flash.message}}}
      </div>
    {{/if}}
    <nav>
      <ul>
        <li><a href="/">VolunteerCenter home</a></li>
        <li><a href="/volunteers">Volunteers</a></li>
        <li><a href="/sites">Sites</a></li>
        <li><a href="/roles">Roles</a></li>
        {{#if currentUser}}
            <li><a href="/users/profile">Welcome {{currentUser.name}}</a></li>
            <li><form action="/users/logout" role="form" method="post">
            <input type="hidden" name="_csrf" value="{{_csrfToken}}">
                    <button type="submit" class="btn">Logout</button>
                </form></li>
            {{else}}
            <li><a href="/users/register">Register as a Volunteer!</a></li>
            <li><a href="/users/login">Volunteer Login</a></li>
         {{/if}}
      </ul>
    </nav>
    {{{body}}}
  </body>
</html>
